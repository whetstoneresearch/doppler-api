# Required
API_KEY=replace-with-api-key
# Optional extra keys (comma-separated). API_KEY remains valid.
API_KEYS=
PRIVATE_KEY=0xyour_private_key
RPC_URL=https://base-sepolia-rpc.publicnode.com

# Optional core
PORT=3000
LOG_LEVEL=info
DEFAULT_CHAIN_ID=84532
READY_RPC_TIMEOUT_MS=2000
CORS_ORIGINS=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Optional idempotency
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_REQUIRE_KEY=false
IDEMPOTENCY_TTL_MS=86400000
IDEMPOTENCY_STORE_PATH=.data/idempotency-store.json

# Optional chain defaults
DEFAULT_NUMERAIRE_ADDRESS=0x4200000000000000000000000000000000000006
# Optional JSON map to enable multichain runtime contexts
# CHAIN_CONFIG_JSON={"84532":{"rpcUrl":"https://base-sepolia-rpc.publicnode.com","defaultNumeraireAddress":"0x4200000000000000000000000000000000000006","auctionTypes":["multicurve"],"migrationModes":["noOp"],"governanceModes":["noOp","default"],"governanceEnabled":true}}

# Optional pricing
PRICE_ENABLED=true
PRICE_PROVIDER=coingecko
PRICE_BASE_URL=https://api.coingecko.com/api/v3
PRICE_TIMEOUT_MS=3000
PRICE_CACHE_TTL_MS=15000
PRICE_API_KEY=
PRICE_COINGECKO_ASSET_ID=ethereum

# Optional live tests
LIVE_TEST_ENABLE=false
LIVE_NUMERAIRE_PRICE_USD=3000
